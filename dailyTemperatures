class Solution:
    def dailyTemperatures(self, temperatures: List[int]) -> List[int]:
        n=len(temperatures)
        index=[]
        res=[0 for _ in range(n)]
        index.append(0)
        for i in range(1,n):
            while index and temperatures[i]>temperatures[index[-1]]:
                res[index[-1]]=i-index[-1]
                index.pop()
            index.append(i)
        return res

