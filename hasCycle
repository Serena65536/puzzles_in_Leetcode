# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, x):
#         self.val = x
#         self.next = None

class Solution:
    def hasCycle(self, head: Optional[ListNode]) -> bool:
        s=10**6
        if not head:
            return False
        while head.next:
            head.val=s
            head=head.next
            if head.val==s:
                return True
        return False
