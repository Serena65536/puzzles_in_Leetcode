class Solution:   
    def numSquares(self, n: int) -> int:
        def square(i):
            return int(i**0.5)
        s=[0 for _ in range(n)]
        for i in range(n):
            s_min=2**30
            for j in range(1,square(i+1)+1):
                s_min=min(s_min,s[i-j*j])
            s[i]=1+s_min
        return s[n-1]
