class Solution:
    def canCompleteCircuit(self, gas: List[int], cost: List[int]) -> int:
        #也就是说从某一点开始后前一个数组的前n项和一定大于后一个数组
        n=len(gas)
        if sum(gas)<sum(cost):
            return -1
        remaining=[None]*n
        for i in range(n):
            remaining[i]=gas[i]-cost[i]
        def start(nums,i):
            s=0
            l=len(nums)           
            for j in range(l):                
                s+=nums[(i+j)%l]
                if s<0:
                     return False
            return True
        for i in range(n):
            if remaining[i]==0 and n>1:
                continue
            if n>1 and i>0 and remaining[i]==remaining[i-1]:
                continue 
            if start(remaining,i):
                return i
