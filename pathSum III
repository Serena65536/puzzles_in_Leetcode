# Definition for a binary tree node.
# class TreeNode:
#     def __init__(self, val=0, left=None, right=None):
#         self.val = val
#         self.left = left
#         self.right = right
class Solution:
    def pathSum(self, root: Optional[TreeNode], targetSum: int) -> int:
        s=0
        def dfs(r,num,visited):
            nonlocal s
            if not r:
                return
            if r.val==num:
                s+=1
            if not visited:               
                dfs(r.left,num,False)
                dfs(r.right,num,False)
            dfs(r.left,num-r.val,True)
            dfs(r.right,num-r.val,True)
        dfs(root,targetSum,False)
        return s

