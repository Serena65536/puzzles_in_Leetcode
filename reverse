class Solution:
    def reverse(self, x: int) -> int:
        if abs(x)<10:
            return x
        else:
            n = abs(x)
            s = 0
            while n>0:
                s = s*10 + n % 10
                n //= 10
            if x<0 and s< (2**31)+1:
                return -s
            elif x>0 and s<(2**31):
                 return s
            else:
                 return 0
