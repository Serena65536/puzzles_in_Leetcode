class Solution:
    def maxProfit(self, prices: List[int]) -> int:
        n=len(prices)
        min_sum=prices[0]
        if n==1:
            return 0
        profit=prices[1]-prices[0]
        for i in range(1,n):            
            profit=max(profit,prices[i]-min_sum)
            min_sum=min(min_sum,prices[i])
        if profit<0:
            profit=0           
        return profit
