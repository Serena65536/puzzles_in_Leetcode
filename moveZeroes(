class Solution:
    def moveZeroes(self, nums: List[int]) -> None:
        n=len(nums)
        left=0
        right=n-1
        while left<right:
            if nums[left]!=0:
                left+=1
            else:
                nums.pop(left)
                nums.append(0)               
                right-=1

