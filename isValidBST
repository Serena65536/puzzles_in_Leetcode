# Definition for a binary tree node.
# class TreeNode:
#     def __init__(self, val=0, left=None, right=None):
#         self.val = val
#         self.left = left
#         self.right = right
class Solution:
    def isValidBST(self, root: Optional[TreeNode]) -> bool:
        res=[]
        def dfs(r):
            if not r:
                return
            dfs(r.left)
            res.append(r.val)
            dfs(r.right)
        dfs(root)
        if len(res)==1:
            return True
        for i in range(1,len(res)):
            if res[i]-res[i-1]<=0:
                return False
        return True
        
