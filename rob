class Solution:
    def rob(self, nums: List[int]) -> int:
        n=len(nums)
        rob_num=[None]*n
        rob_num[0]=nums[0]
        if n>1:
            rob_num[1]=max(nums[0],nums[1])
        if n>2:
             for i in range(2,n):
                 rob_num[i]=max(rob_num[i-1],rob_num[i-2]+nums[i])
        return rob_num[n-1]
        
